{
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "tsc",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "start": "node dist/server.js",
    "test": "vitest run --pool=forks --no-file-parallelism --maxWorkers=1 --reporter=dot",
    "validate:savepoint": "node scripts/validate-save-point.mjs",
    "migrate": "tsx src/scripts/run-migrations.ts",
    "migrate:test": "dotenv -e .env.test -- tsx src/scripts/run-migrations.ts",
    "seed:liveops-demo": "tsx src/scripts/seed-live-ops-demo.ts",
    "suggest:nextstep": "node scripts/suggest-next-build-step.mjs origin/main"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
